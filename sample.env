# Telegram API 凭证（必填）
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH
BOT_TOKEN=YOUR_BOT_TOKEN

# 管理员和所有者 ID
DEVELOPER_USER_ID=YOUR_USER_ID

# ── User Tracking ─────────────────────────────────────────────────────────
# LOG_GROUP_ID：下载的文件将记录到此群组。
# 机器人需要是该群组的管理员（需要发送消息权限）。
# 示例：-1001234567890
LOG_GROUP_ID=YOUR_LOG_GROUP_ID

# 数据库 URL
# 仅 MONGO_URL 是必填的。DATABASE_URL 和 DB_URL 是可选的（回退到 MONGO_URL）。
MONGO_URL=YOUR_MONGO_URL
# DATABASE_URL=YOUR_DATABASE_URL
# DB_URL=YOUR_DB_URL

# 强制订阅频道（不带 @ 的用户名）
# 用户必须加入此频道才能使用机器人。
# 留空以禁用强制订阅。
FORCE_SUB_CHANNEL=

# 机器人命令前缀
COMMAND_PREFIX=!|.|#|,|/
